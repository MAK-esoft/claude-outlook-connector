# ── Server ──────────────────────────────────────────────────────────────
PUBLIC_URL=                 # public HTTPS base URL, no trailing slash (tunnel or deployed)
PORT=3000

# ── Vault (encrypted credential store) ──────────────────────────────────
# Generate the key once with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# If lost, all stored tokens are undecryptable and every mailbox must re-enroll.
VAULT_ENCRYPTION_KEY=       # 32-byte base64
VAULT_STORE_PATH=./vault.enc.json

# ── Mailbox provider: Microsoft (Entra) ─────────────────────────────────
# Redirect URI to register (type Web): <PUBLIC_URL>/enroll/callback/microsoft
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# ── Mailbox provider: Google ────────────────────────────────────────────
# Redirect URI to register: <PUBLIC_URL>/enroll/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Read access (this build reads mailboxes too, not just send) ─────────
# Set false to request send-only scopes at enrollment (spec's least-privilege
# default). Set true to also request Mail.Read / gmail.readonly so the read
# tools work. Changing this requires re-enrolling affected mailboxes.
ENABLE_READ_SCOPES=true

# ── Auth0 client (multi-user enrollment login) ──────────────────────────
# The SAME Auth0 application is used two ways: (1) the /enroll portal logs
# mailbox owners in with it server-side, (2) Claude/ChatGPT use it as their
# OAuth client when connecting. When both values are set, /enroll requires
# login and every mailbox is owned by the user who enrolled it; when blank,
# the portal runs in single-user dev mode.
# Its Allowed Callback URLs in Auth0 must include:
#   <PUBLIC_URL>/enroll/auth/callback   (the portal)
#   plus the Claude/ChatGPT callbacks (see PLATFORM_NOTES.md)
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ── Operator auth (Layer A) — platform-agnostic ─────────────────────────
# Authenticates the HUMAN using Claude/ChatGPT. Keep false only for early,
# throwaway-mailbox smoke tests on Claude. MUST be true before real mailboxes
# or ChatGPT.
OPERATOR_AUTH_ENABLED=false
OPERATOR_ISSUER=                   # e.g. https://YOUR_TENANT.us.auth0.com/
OPERATOR_JWKS_URL=                 # e.g. https://YOUR_TENANT.us.auth0.com/.well-known/jwks.json
OPERATOR_AUDIENCE=                 # = <PUBLIC_URL>/mcp
OPERATOR_ALLOWLIST=                # comma-separated operator emails allowed to use the connector
OPERATOR_REQUIRED_SCOPE=           # optional scope your AS issues, e.g. email.send

# ── Defense-in-depth (optional) ─────────────────────────────────────────
INGRESS_IP_ALLOWLIST=              # comma-separated CIDR ranges (Anthropic + OpenAI egress)
