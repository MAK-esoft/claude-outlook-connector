# Copy to .env (or set these as environment variables on your host).
# PUBLIC_URL is the externally reachable HTTPS base URL of THIS server
# (e.g. https://your-app.onrender.com) — no trailing slash. Required.
PUBLIC_URL=

# Port to listen on. Most PaaS hosts inject their own PORT env var; the
# server honors it automatically. Locally, defaults to 3000 if unset.
PORT=3000
